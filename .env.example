# Environment Variables for KudoBit Project

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Optional: WalletConnect project ID for enhanced wallet support
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network configurations (already configured in hardhat.config.js)
# Monad Testnet
# RPC_URL=https://testnet-rpc.monad.xyz
# CHAIN_ID=10143

# Instructions:
# 1. Copy this file to .env
# 2. Add your private key (without 0x prefix)
# 3. Get test MON from: https://faucet.monad.xyz
# 4. Deploy contracts: npx hardhat run scripts/deploy.cjs --network monadTestnet
